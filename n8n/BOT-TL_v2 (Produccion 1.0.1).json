    {
      "parameters": {
        "jsCode": "// 1. Obtenemos el texto que entregó Gemini\nlet textoGemini = $input.item.json.content.parts[0].text;\n\n// 2. Limpieza de seguridad: Quitamos las etiquetas markdown (```json) por si la IA es terca\ntextoGemini = textoGemini.replace(/```json/gi, '').replace(/```/g, '').trim();\n\n// 3. Convertimos el texto directamente a un objeto estructurado\nlet datosIA;\ntry {\n  datosIA = JSON.parse(textoGemini);\n} catch (error) {\n  throw new Error(\"El radar falló: Gemini no devolvió un JSON válido. Respuesta cruda: \" + textoGemini);\n}\n\n// 4. Armamos el paquete final para inyectar en la base de datos (Supabase)\nreturn {\n  json: {\n    estado_ia: datosIA.estado_ia,\n    orden_ejecucion: datosIA.orden_ejecucion,\n    ticker_objetivo: datosIA.ticker_objetivo,\n    bitacora_calculo: datosIA.bitacora_calculo,\n    texto_crudo: textoGemini // Guardamos el JSON crudo por seguridad\n  }\n};"
      },
