    {
      "parameters": {
        "jsCode": "const resultados = $input.all();\n\n// Si solo llegó 1 item (loop no terminó aún), no procesar\nif (resultados.length < 6) {\n  return [{ json: { _debug: `Solo ${resultados.length} items recibidos, esperando más` } }];\n}\n\nlet fila = /** @type {Record<string, unknown>} */ ({});\n\nresultados.forEach(item => {\n  // Defensive: verifica que la estructura exista\n  const result = item.json?.chart?.result?.[0];\n  if (!result) return;\n\n  const meta = result.meta;\n  const closes = result.indicators?.quote?.[0]?.close ?? [];\n  \n  const valid = closes.filter(v => v != null && !isNaN(v));\n  const prev  = valid.length >= 2 ? valid[valid.length - 2] : null;\n  const curr  = meta.regularMarketPrice;\n  const delta = prev != null\n    ? parseFloat(((curr - prev) / prev * 100).toFixed(2))\n    : null;\n\n  const map = {\n    '^VIX':     ['vix',     'vix_delta'],\n    'CL=F':     ['wti',     'wti_delta'],\n    'GC=F':     ['oro',     'oro_delta'],\n    '^TNX':     ['bono10y', 'bono10y_delta'],\n    'DX-Y.NYB': ['dxy',     'dxy_delta'],\n    'HG=F':     ['cobre',   'cobre_delta'],\n  };\n\n  const keys = map[meta.symbol];\n  if (keys) {\n    fila[keys[0]] = curr;\n    fila[keys[1]] = delta;\n  }\n});\n\n// Verifica que llegaron los 6 símbolos esperados\nconst esperados = ['vix','wti','oro','bono10y','dxy','cobre'];\nconst faltantes = esperados.filter(k => fila[k] === undefined);\nif (faltantes.length > 0) {\n  fila._advertencia = `Faltan datos de: ${faltantes.join(', ')}`;\n}\n\nreturn [{ json: fila }];"
      },
